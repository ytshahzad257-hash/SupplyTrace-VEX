# SupplyTrace-VEX local configuration example.
# Copy to .env for local experiments. Do not commit real environment files.

# Root directories for generated evidence.
SUPPLYTRACE_ARTIFACTS_DIR=artifacts
SUPPLYTRACE_TESTBED_DIR=testbed

# Comma-separated scanner adapter list.
# Supported names: osv, trivy, grype, npm-audit, pip-audit.
SUPPLYTRACE_SCANNERS=osv,trivy,grype,npm-audit,pip-audit

# Keep false for reproducible local-only runs unless a scanner explicitly needs
# its own database-update behavior and the study documents that choice.
SUPPLYTRACE_ALLOW_NETWORK_SCANNER_UPDATES=false

# npm audit queries the npm advisory service by default while scanning only the
# local package-lock in each generated case. Set true only for cached/offline
# npm-audit experiments; offline mode may return zero advisories if no advisory
# data is cached locally.
SUPPLYTRACE_NPM_AUDIT_OFFLINE=false

# Optional JSON file containing scoring weight overrides.
# Leave empty to use the built-in conservative defaults.
SUPPLYTRACE_SCORING_WEIGHTS_FILE=
